{
  "version": "0.2",
  "language": "en,en-US",
  "import": ["../manual/.cspell.json"],
  "ignorePaths": [
    "build/**",
    "tests/fixtures/**",
    "agent-reports/**",
    "transcripts/**"
  ],
  "ignoreRegExpList": [
    "(ms1|mk1|md1)[a-z0-9]+",
    "0x[a-fA-F0-9]+",
    "https?://[^\\s)]+",
    "`[^`]+`"
  ],
  "words": ["custodied", "MSRV", "pasteable", "PSBT", "rekt", "rustc"]
}
