[ mnemonic > nostr ]
  --all-script-types  checkbox  -> [ ] off
  --import            text  -> <empty>
  --json              checkbox  -> [ ] off
  --network           dropdown[mainnet,testnet,signet,regtest]  -> mainnet
  --no-auto-repair    checkbox  -> [ ] off
  --pubkey            text  -> <empty>
  --script-type       text  -> <empty>
  --secret            text  (secret) -> <masked>
  --secret-file       path  -> <empty>
  --secret-stdin      checkbox  (secret) -> [ ] off [disabled]
  --timestamp         text  -> 0
  [ Run ]
