[ mnemonic > electrum-decrypt ]
  --ciphertext              text  (required) -> <empty>
  --decrypt-password        text  (secret) -> <masked>
  --decrypt-password-file   path  -> <empty>
  --decrypt-password-stdin  checkbox  (secret) -> [ ] off [disabled]
  --json-out                path  -> <empty>
  --no-auto-repair          checkbox  -> [ ] off
  [ Run ]
