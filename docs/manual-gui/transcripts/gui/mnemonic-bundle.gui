[ mnemonic > bundle ]
  --group-size            number  -> <unset>
  --separator             dropdown[space,hyphen,comma]  -> space
  --network               dropdown[mainnet,testnet,signet,regtest]  (required) -> mainnet
  --template              dropdown[bip44,bip49,bip84,bip86,wsh-multi,wsh-sortedmulti,sh-wsh-multi,sh-wsh-sortedmulti,tr-multi-a,tr-sortedmulti-a]  (required) -> bip44
  --descriptor            text  -> <empty>
  --descriptor-file       path  -> <empty>
  --import-json           path(stdio)  -> <empty>
  --import-json-index     number  -> <unset>
  --language              dropdown[english,simplifiedchinese,traditionalchinese,czech,french,italian,japanese,korean,portuguese,spanish]  -> english
  --passphrase            text  (secret) -> <masked>
  --passphrase-stdin      checkbox  (secret) -> [ ] off [disabled]
  --account               number  -> <unset>
  --json                  checkbox  -> [ ] off
  --no-engraving-card     checkbox  -> [ ] off
  --multisig-path-family  dropdown[bip48,bip87]  -> bip48 [disabled]
  --md1-form              dropdown[policy,template]  -> policy
  --privacy-preserving    checkbox  -> [ ] off
  --self-check            checkbox  -> [ ] off
  --threshold             number  -> <unset> [disabled]
  --no-auto-repair        checkbox  -> [ ] off
  [ slot editor: 0 rows ]
  [ Run ]
