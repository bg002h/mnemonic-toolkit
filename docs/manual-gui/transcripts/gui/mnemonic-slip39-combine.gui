[ mnemonic > slip39-combine ]
  --share             text  (required, secret, repeating) -> <masked> [reveal]
  --passphrase        text  (secret) -> <masked> [reveal]
  --passphrase-stdin  checkbox  (secret) -> [ ] off [disabled]
  --to                dropdown[entropy,phrase]  -> entropy
  --json-out          path  -> <empty>
  --no-auto-repair    checkbox  -> [ ] off
  [ Run ]
